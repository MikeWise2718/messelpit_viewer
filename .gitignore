# --- kit-app-template build artifacts (regenerated by repo.bat build) ---
kit-app-template/_build/
kit-app-template/_compiler/
kit-app-template/_repo/
kit-app-template/.omniverse_eula_accepted.txt
kit-app-template/build.log
kit-app-template/launch.log
kit-app-template/log.txt

# --- per-app generated artifacts ---
# Version locks are regenerated on every build with kit_version-specific hashes;
# tracking them creates merge noise without aiding reproducibility.
kit-app-template/source/apps/*.kit.lock

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# --- VSCode local-only state ---
# Note: .vscode/replay_files/ IS tracked (drives non-interactive scaffolding).
kit-app-template/.vscode/settings.json

# --- OS / editor noise ---
Thumbs.db
.DS_Store
*.swp
*~

# --- agent state ---
.claude/
